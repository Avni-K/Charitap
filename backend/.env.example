MONGODB_URI=mongodb://mongodb:27017/charitap
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
JWT_SECRET=your_jwt_secret_key_here
PORT=3001

# ResilientDB Blockchain
RESILIENTDB_ENABLED=true
RESILIENTDB_FAIL_SILENTLY=true
RESILIENTDB_GRAPHQL_URL=https://cloud.resilientdb.com/graphql

# ResContract Smart Contract (deployed via WSL ResilientDB)
RESCONTRACT_ENABLED=true
RESCONTRACT_MODE=wsl
RESCONTRACT_OWNER_ADDRESS=
RESCONTRACT_CONTRACT_ADDRESS=
RESCONTRACT_CONTRACT_NAME=
RESCONTRACT_FAIL_SILENTLY=true

# Cloud ResContract Smart Contract
CLOUD_RESCONTRACT_OWNER_ADDRESS=
CLOUD_RESCONTRACT_CONTRACT_ADDRESS=

# Solana local validator / USDC receipts
SOLANA_ENABLED=false
SOLANA_FAIL_SILENTLY=true
SOLANA_ALLOW_UNVERIFIED_LOCAL_PAYMENTS=false
SOLANA_RPC_URL=http://localhost:8899
SOLANA_WS_URL=ws://localhost:8900
SOLANA_PROGRAM_ID=
SOLANA_USDC_MINT=
SOLANA_FEE_PAYER_KEYPAIR=
SOLANA_TREASURY_WALLET=

# Atlas Charts / Triggers / Vector Search
ATLAS_TRIGGER_SECRET=
ATLAS_VECTOR_SEARCH_ENABLED=false
ATLAS_VECTOR_SEARCH_INDEX=charity_vector_index
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMENSIONS=128
ZIP_GEOCODER_PROVIDER=local

# CSRF Protection
CSRF_SECRET=your-csrf-secret-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
EMAIL_ENABLED=false
EMAIL_FROM=
ADMIN_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ADMIN_EMAILS=
